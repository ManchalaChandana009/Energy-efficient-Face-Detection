CAMERA_INDEX=0
DETECTOR_MODEL_PATH=models/face_detection_yunet_2023mar.onnx
RECOGNIZER_MODEL_PATH=models/face_recognition_sface_2021dec.onnx
KNOWN_FACES_DIR=data/known_faces
ATTENDANCE_LOG_PATH=data/attendance.csv
MATCH_THRESHOLD=0.55
FRAME_WIDTH=640
FRAME_HEIGHT=480
AUTO_ALERT_ON_UNKNOWN=true
CAPTURE_COOLDOWN_SECONDS=3
ATTENDANCE_COOLDOWN_SECONDS=10
ESP32_API_BASE_URL=
ESP32_DISCOVERY_ENABLED=true
ESP32_MDNS_SERVICE=_edgeface._tcp.local.
ESP32_SCAN_TIMEOUT_SECONDS=4
